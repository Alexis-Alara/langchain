# Configuración principal
OPENAI_API_KEY=tu_openai_api_key_aqui
TENANT_ID=default
TIMEZONE=America/Mexico_City

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=impulso_chatbot

# WhatsApp Business API Configuration
WHATSAPP_ACCESS_TOKEN=tu_whatsapp_access_token_aqui
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id_aqui
WHATSAPP_VERIFY_TOKEN=IMPULSO_VERIFY_TOKEN

# Meta Messaging (Messenger + Instagram) Configuration
META_PAGE_ID=tu_meta_page_id_aqui
META_PAGE_ACCESS_TOKEN=tu_meta_page_access_token_aqui
META_VERIFY_TOKEN=IMPULSO_META_VERIFY_TOKEN
# Opcional pero recomendado para validar firma de webhook
META_APP_SECRET=tu_meta_app_secret_aqui
# Version de Graph API usada para Messenger/Instagram
META_GRAPH_VERSION=v21.0

# Webhook URL (para desarrollo con ngrok)
# WEBHOOK_URL=https://tu-ngrok-url.ngrok.io
